{
  "info": {
    "name": "Event Management Microservices",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Complete API collection for Event Management microservices. All requests go through the API Gateway on port 8081. Set the 'token' collection variable after login."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token saved:', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users/api/auth/login", "host": ["{{baseUrl}}"], "path": ["users", "api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users/api/users/register", "host": ["{{baseUrl}}"], "path": ["users", "api", "users", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"contactNumber\": \"9876543210\",\n  \"role\": \"ROLE_USER\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users/api/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["users", "api", "auth", "forgot-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users/api/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["users", "api", "auth", "reset-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"reset-token-here\",\n  \"newPassword\": \"newpassword123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/api/users/all", "host": ["{{baseUrl}}"], "path": ["users", "api", "users", "all"] }
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/api/users/1", "host": ["{{baseUrl}}"], "path": ["users", "api", "users", "1"] }
          }
        },
        {
          "name": "Get Users Batch",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/users/api/users/batch", "host": ["{{baseUrl}}"], "path": ["users", "api", "users", "batch"] },
            "body": {
              "mode": "raw",
              "raw": "[1, 2, 3]"
            }
          }
        },
        {
          "name": "Approve Organizer (Admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/api/users/admin/approve/1", "host": ["{{baseUrl}}"], "path": ["users", "api", "users", "admin", "approve", "1"] }
          }
        },
        {
          "name": "Get Pending Organizers (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/api/users/admin/pending", "host": ["{{baseUrl}}"], "path": ["users", "api", "users", "admin", "pending"] }
          }
        },
        {
          "name": "Get Recipients (Internal)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/api/users/recipients", "host": ["{{baseUrl}}"], "path": ["users", "api", "users", "recipients"] }
          }
        },
        {
          "name": "Get Event Context (Internal)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/api/users/1/event-context", "host": ["{{baseUrl}}"], "path": ["users", "api", "users", "1", "event-context"] }
          }
        },
        {
          "name": "Get Ticket Context (Internal)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/api/users/1/ticket-context", "host": ["{{baseUrl}}"], "path": ["users", "api", "users", "1", "ticket-context"] }
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/events/events", "host": ["{{baseUrl}}"], "path": ["events", "events"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tech Conference 2025\",\n  \"category\": \"Technology\",\n  \"location\": \"Chennai\",\n  \"eventDate\": \"2025-12-01\",\n  \"startTime\": \"2025-12-01T09:00:00\",\n  \"endTime\": \"2025-12-01T18:00:00\",\n  \"description\": \"Annual tech conference\",\n  \"ticketPrice\": 500.00,\n  \"totalCapacity\": 200,\n  \"organizerId\": 1\n}"
            }
          }
        },
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/events/events", "host": ["{{baseUrl}}"], "path": ["events", "events"] }
          }
        },
        {
          "name": "Get Event By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/events/events/1", "host": ["{{baseUrl}}"], "path": ["events", "events", "1"] }
          }
        },
        {
          "name": "Update Event",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/events/events/1", "host": ["{{baseUrl}}"], "path": ["events", "events", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tech Conference 2025 Updated\",\n  \"category\": \"Technology\",\n  \"location\": \"Chennai\",\n  \"eventDate\": \"2025-12-01\",\n  \"startTime\": \"2025-12-01T09:00:00\",\n  \"endTime\": \"2025-12-01T18:00:00\",\n  \"description\": \"Updated description\",\n  \"ticketPrice\": 600.00,\n  \"totalCapacity\": 250,\n  \"organizerId\": 1\n}"
            }
          }
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/events/events/1", "host": ["{{baseUrl}}"], "path": ["events", "events", "1"] }
          }
        },
        {
          "name": "Get Ticket Info (Internal)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/events/events/1/ticket-info", "host": ["{{baseUrl}}"], "path": ["events", "events", "1", "ticket-info"] }
          }
        },
        {
          "name": "Reduce Seats (Internal)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/events/events/1/reduce-seats?count=2", "host": ["{{baseUrl}}"], "path": ["events", "events", "1", "reduce-seats"], "query": [{ "key": "count", "value": "2" }] }
          }
        },
        {
          "name": "Increase Seats (Internal)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/events/events/1/increase-seats?count=2", "host": ["{{baseUrl}}"], "path": ["events", "events", "1", "increase-seats"], "query": [{ "key": "count", "value": "2" }] }
          }
        },
        {
          "name": "Trigger Feedback",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/events/events/1/feedback", "host": ["{{baseUrl}}"], "path": ["events", "events", "1", "feedback"] }
          }
        },
        {
          "name": "Search Events",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/events/events/search?category=Technology&location=Chennai&date=2025-12-01",
              "host": ["{{baseUrl}}"],
              "path": ["events", "events", "search"],
              "query": [
                { "key": "category", "value": "Technology" },
                { "key": "location", "value": "Chennai" },
                { "key": "date", "value": "2025-12-01" }
              ]
            }
          }
        },
        {
          "name": "Events By Category",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/events/events/category/Technology", "host": ["{{baseUrl}}"], "path": ["events", "events", "category", "Technology"] }
          }
        },
        {
          "name": "Events By Location",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/events/events/location/Chennai", "host": ["{{baseUrl}}"], "path": ["events", "events", "location", "Chennai"] }
          }
        },
        {
          "name": "Events By Organizer",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/events/events/organizer/1", "host": ["{{baseUrl}}"], "path": ["events", "events", "organizer", "1"] }
          }
        },
        {
          "name": "Events By Time Range",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/events/events/range?start=2025-01-01T00:00:00&end=2025-12-31T23:59:59",
              "host": ["{{baseUrl}}"],
              "path": ["events", "events", "range"],
              "query": [
                { "key": "start", "value": "2025-01-01T00:00:00" },
                { "key": "end", "value": "2025-12-31T23:59:59" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Book Ticket",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/tickets/tickets/book", "host": ["{{baseUrl}}"], "path": ["tickets", "tickets", "book"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": 1,\n  \"userId\": 1,\n  \"quantity\": 2\n}"
            }
          }
        },
        {
          "name": "Cancel Ticket",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/tickets/tickets/cancel/1", "host": ["{{baseUrl}}"], "path": ["tickets", "tickets", "cancel", "1"] }
          }
        },
        {
          "name": "Payment Success (Stripe Callback)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tickets/tickets/payment/success?session_id=cs_test_xxx",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "tickets", "payment", "success"],
              "query": [{ "key": "session_id", "value": "cs_test_xxx" }]
            }
          }
        },
        {
          "name": "Payment Cancel (Stripe Callback)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/tickets/tickets/payment/cancel", "host": ["{{baseUrl}}"], "path": ["tickets", "tickets", "payment", "cancel"] }
          }
        },
        {
          "name": "Get Tickets By User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/tickets/tickets/user/1", "host": ["{{baseUrl}}"], "path": ["tickets", "tickets", "user", "1"] }
          }
        },
        {
          "name": "Get Tickets By Event",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/tickets/tickets/event/1", "host": ["{{baseUrl}}"], "path": ["tickets", "tickets", "event", "1"] }
          }
        },
        {
          "name": "Get Attendees For Feedback (Internal)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/tickets/tickets/feedback/event/1", "host": ["{{baseUrl}}"], "path": ["tickets", "tickets", "feedback", "event", "1"] }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/notifications/api/v1/notifications", "host": ["{{baseUrl}}"], "path": ["notifications", "api", "v1", "notifications"] }
          }
        },
        {
          "name": "Send Single Notification (Internal)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/notifications/api/v1/notifications/send", "host": ["{{baseUrl}}"], "path": ["notifications", "api", "v1", "notifications", "send"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"recipient\": \"user@example.com\",\n  \"templateName\": \"WELCOME_USER\",\n  \"type\": \"EMAIL\",\n  \"templateData\": {\n    \"userName\": \"John Doe\"\n  }\n}"
            }
          }
        },
        {
          "name": "Send Bulk Notifications (Internal)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/notifications/api/v1/notifications/bulk", "host": ["{{baseUrl}}"], "path": ["notifications", "api", "v1", "notifications", "bulk"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"templateName\": \"EVENT_CREATED\",\n  \"type\": \"EMAIL\",\n  \"commonData\": {\n    \"eventName\": \"Tech Conference 2025\"\n  },\n  \"recipients\": [\n    { \"userId\": 1, \"email\": \"user1@example.com\" },\n    { \"userId\": 2, \"email\": \"user2@example.com\" }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get User Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/notifications/api/v1/notifications/user/1", "host": ["{{baseUrl}}"], "path": ["notifications", "api", "v1", "notifications", "user", "1"] }
          }
        },
        {
          "name": "Get Unread Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/notifications/api/v1/notifications/user/1/unread", "host": ["{{baseUrl}}"], "path": ["notifications", "api", "v1", "notifications", "user", "1", "unread"] }
          }
        },
        {
          "name": "Mark Notification As Read",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/notifications/api/v1/notifications/1/read", "host": ["{{baseUrl}}"], "path": ["notifications", "api", "v1", "notifications", "1", "read"] }
          }
        },
        {
          "name": "Delete Notification",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/notifications/api/v1/notifications/1", "host": ["{{baseUrl}}"], "path": ["notifications", "api", "v1", "notifications", "1"] }
          }
        }
      ]
    },
    {
      "name": "Feedback",
      "item": [
        {
          "name": "Initiate Feedback Cycle (Internal)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/feedback/feedback/initiate", "host": ["{{baseUrl}}"], "path": ["feedback", "feedback", "initiate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": 1,\n  \"eventName\": \"Tech Conference 2025\"\n}"
            }
          }
        },
        {
          "name": "Submit Feedback",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/feedback/feedback/submit/1", "host": ["{{baseUrl}}"], "path": ["feedback", "feedback", "submit", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Excellent event, very well organized!\"\n}"
            }
          }
        },
        {
          "name": "Get Average Rating",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/feedback/feedback/average/1", "host": ["{{baseUrl}}"], "path": ["feedback", "feedback", "average", "1"] }
          }
        },
        {
          "name": "Get All Comments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/feedback/feedback/comments/1", "host": ["{{baseUrl}}"], "path": ["feedback", "feedback", "comments", "1"] }
          }
        },
        {
          "name": "Get User Feedback For Event",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/feedback/feedback/event/1/user/1", "host": ["{{baseUrl}}"], "path": ["feedback", "feedback", "event", "1", "user", "1"] }
          }
        }
      ]
    }
  ]
}
