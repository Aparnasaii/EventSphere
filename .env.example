# EventSphere environment variables
# Copy this file to ".env" and fill in real values.
# DO NOT commit the .env file — it is gitignored.

# ─────────── Database ────────────────
DB_URL=jdbc:mysql://localhost:3306/eventmanagementdb
DB_USERNAME=root
DB_PASSWORD=root

# ─────────── JWT ─────────────────────
# Generate a random 64-char hex string. SAME value across all services.
JWT_SECRET=replace-with-long-random-secret-min-32-chars

# ─────────── Bootstrap admin ─────────
ADMIN_EMAIL=admin@event.com
ADMIN_PASSWORD=change-this-on-first-login
ADMIN_FULLNAME=System Admin

# ─────────── Stripe ──────────────────
# Get your key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key_here

# ─────────── Mail (Notification svc — SendGrid) ──────
# Sign up at https://sendgrid.com and create an API key.
# spring.mail.username stays "apikey"; only the password is the API key.
MAIL_PASSWORD=SG.your_sendgrid_api_key_here
MAIL_FROM=eventsphere.example@gmail.com

# ─────────── Mail (User svc — Gmail App Password) ────
MAIL_USERNAME=your.gmail@gmail.com
# Generate a 16-char Gmail App Password at https://myaccount.google.com/apppasswords
# (Requires 2-factor authentication enabled on your Gmail account.)